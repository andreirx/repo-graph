# Enforce engines.node from package.json. Without this, pnpm/npm
# treat engine mismatches as warnings and silently proceed, which
# produces the recurring better-sqlite3 NODE_MODULE_VERSION mismatch
# failure mode at runtime instead of at install time.
#
# See .nvmrc / .tool-versions for the exact pinned Node version
# and CLAUDE.md "Native dependency note" for the rationale.
engine-strict=true
