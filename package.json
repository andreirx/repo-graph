{
  "name": "repo-graph",
  "version": "0.1.0",
  "description": "Deterministic code graph tool for analyzing legacy codebases",
  "type": "module",
  "bin": {
    "rgr": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && vitest run",
    "test:int": "vitest run test/adapters",
    "test:cli": "tsc && vitest run test/cli",
    "test:watch": "vitest",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "clean": "rm -rf dist",
    "build:grammars": "node scripts/build-grammars.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "code-analysis",
    "dependency-graph",
    "legacy-code",
    "static-analysis",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "tree-sitter-cli"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.2",
    "tree-sitter-cli": "^0.26.8",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "vitest": "^4.1.2"
  }
}
